% =========================================================
% Custom Beamer Theme — mytheme.sty
% =========================================================

\ProvidesPackage{pmi-theme}

% === Dependencies ===
\usepackage{tikz}
\usepackage{fontspec}
\usefonttheme{professionalfonts}

\newcommand{\idnum}[1]{\def\insertidnum{#1}}



% === Fonts ===
\setmainfont{Trebuchet MS}
\setsansfont{Trebuchet MS}

% === Font Styles ===
\setbeamerfont{title}{family=\sffamily,series=\bfseries,size=\Huge}
\setbeamerfont{subtitle}{family=\sffamily,series=\bfseries,size=\Large}
\setbeamerfont{frametitle}{family=\sffamily,series=\bfseries,size=\Large}
\setbeamerfont{framesubtitle}{family=\sffamily,series=\bfseries,size=\large}



% === Colors ===
\setbeamercolor{title}{fg=red!80!black}
\setbeamercolor{frametitle}{fg=red!80!black}
\setbeamercolor{framesubtitle}{fg=red!80!black}
\setbeamercolor{section in toc}{fg=red!80!black}
\setbeamercolor{section in toc}{fg=red!80!black,bg=}
\setbeamercolor{subsection in toc}{fg=red!80!black,bg=}
\setbeamercolor{subsubsection in toc}{fg=red!80!black,bg=}

% PMI Color Palette
\definecolor{pmiRed1}{HTML}{E4002B}
\definecolor{pmiRed2}{HTML}{EB535C}
\definecolor{pmiRed3}{HTML}{F39DA2}
\definecolor{pmiRed4}{HTML}{FCE6E8}

\setbeamercolor{pmiRed1}{bg=pmiRed1}
\setbeamercolor{pmiRed2}{bg=pmiRed2}
\setbeamercolor{pmiRed3}{bg=pmiRed3}
\setbeamercolor{pmiRed4}{bg=pmiRed4}




% === Remove Navigation Symbols ===
\setbeamertemplate{navigation symbols}{}

% === Background Bar ===
\setbeamertemplate{background}{
    \ifbeamer@plainframe
        \begin{beamercolorbox}[wd=.42\paperwidth,ht=0.04\paperheight]{pmiRed1}\end{beamercolorbox}%
        \begin{beamercolorbox}[wd=.26\paperwidth,ht=0.04\paperheight]{pmiRed2}\end{beamercolorbox}%
        \begin{beamercolorbox}[wd=.17\paperwidth,ht=0.04\paperheight]{pmiRed3}\end{beamercolorbox}%
        \begin{beamercolorbox}[wd=.15\paperwidth,ht=0.04\paperheight]{pmiRed4}\end{beamercolorbox}%
    \else
        \begin{beamercolorbox}[wd=.42\paperwidth,ht=0.02\paperheight]{pmiRed1}\end{beamercolorbox}%
        \begin{beamercolorbox}[wd=.26\paperwidth,ht=0.02\paperheight]{pmiRed2}\end{beamercolorbox}%
        \begin{beamercolorbox}[wd=.17\paperwidth,ht=0.02\paperheight]{pmiRed3}\end{beamercolorbox}%
        \begin{beamercolorbox}[wd=.15\paperwidth,ht=0.02\paperheight]{pmiRed4}\end{beamercolorbox}%
  \fi
}

\setbeamertemplate{footline}{
  \leavevmode%
  \hbox to \paperwidth{%
    \hspace{1em}\usebeamercolor[fg]{frametitle}\insertauthor%
    \hfil%
    \usebeamercolor[fg]{frametitle}\insertframenumber/\inserttotalframenumber
    \hspace{1em}%
  }%
  \vskip1ex
}

% === Title Page Template ===
\defbeamertemplate*{title page}{custom}[1][]{
    \begin{center}
        {\includegraphics[width=0.3\linewidth]{logo.png}}\\[1cm]
        {\usebeamerfont{title}\usebeamercolor[fg]{title}\inserttitle}\\[0.4cm]
        {\usebeamerfont{subtitle}\usebeamercolor[fg]{frametitle}\insertsubtitle}\\[1cm]
        {\usebeamerfont{author}\usebeamercolor[fg]{frametitle}\insertauthor\par}
        
        {\usebeamerfont{author}\usebeamercolor[fg]{frametitle}\insertidnum\par}
    \end{center}
}

% === Frame Title Template ===

\setbeamertemplate{frametitle}{
    \nointerlineskip
    \vspace{1.2cm}
    \vskip-1ex
    \begin{beamercolorbox}[wd=\paperwidth,ht=2.5ex,dp=1ex,leftskip=0.5cm]{frametitle}
        \usebeamerfont{frametitle}\insertframetitle\\
        \usebeamerfont{framesubtitle}\insertframesubtitle
    \end{beamercolorbox}
    \vspace{-0.5ex}
}

% === Itemize Style ===
\setbeamertemplate{itemize item}{\color{black}$\bullet$}
\setbeamertemplate{section in toc}{%
  \leavevmode\leftskip=0em%
  \raisebox{0.5pt}{\color{red!80!black}$\blacktriangleright$}\hspace{0.5em}%
  \inserttocsection\par
}

\AtBeginSection[]{
    \begin{frame}[plain]
        \tableofcontents[currentsection] 
    \end{frame}
}

\AtEndDocument{
    \begin{frame}[plain]
    \vfill
    \centering
        \usebeamerfont{title}\usebeamercolor[fg]{title}
        Terima Kasih
    \vfill      
    \end{frame}
}

% === TikZ Defaults ===
\tikzset{every picture/.append style={remember picture=false}}

% === End of Theme ===
